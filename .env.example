# Copy to `.env` in this directory (never commit `.env`).
# Existing shell environment variables take precedence over this file.

ATLASSIAN_EMAIL=you@company.com
ATLASSIAN_API_TOKEN=

# Required for non-placeholder Atlassian access:
ATLASSIAN_BASE_URL=https://your-site.atlassian.net
CONFLUENCE_BASE_URL=https://your-site.atlassian.net/wiki
# Optional aliases:
# JIRA_BASE_URL=https://your-site.atlassian.net
# JIRA_EMAIL=
# JIRA_API_TOKEN=

# Extract thread pool: overrides auto workers from enumerated page count.
# CONFLUENCE_EXTRACT_WORKERS=8
# CONFLUENCE_EXTRACT_WORKERS_MAX=8

# Optional Confluence sync knobs:
# CONFLUENCE_ROOT_PAGE_ID=100001
# CONFLUENCE_ENUM_MODE=cql   # or bfs
# CONFLUENCE_ENUMERATE_PAGE_SIZE=250
# CONFLUENCE_ENUMERATE_CQL='space = DEMO AND type = page AND ancestor = 100001 ORDER BY title'
# CONFLUENCE_CANONICAL_ROOT_IDS=100001
# CONFLUENCE_RESOLVE_CANONICAL_ROOT=1
