{
  "version": 1,
  "description": "通用 S6 读者语言精修策略。这里定义表达形态，不定义具体业务域规则；脚本只读取并报告命中的类别。",
  "checks": [
    {
      "id": "legacy_internal_jargon",
      "label": "旧内部黑话",
      "severity": "error",
      "terms": [
        "详情钻取",
        "钻取",
        "闭环",
        "缺口",
        "主链",
        "迁入",
        "字段全集",
        "可验收字段口径",
        "反向定义业务规则",
        "已承诺口径",
        "未承诺边界",
        "用户可见后果",
        "关联缺口",
        "待定与缺口",
        "待决策/补录",
        "建议责任角色",
        "补齐后影响",
        "补录",
        "口径"
      ],
      "guidance": "改成业务读者能直接理解的规则、边界、影响、待确认事项等表达。"
    },
    {
      "id": "stage_residue",
      "label": "流程阶段残留",
      "severity": "error",
      "terms": [
        "待裁决",
        "待定项",
        "待定展示",
        "尚未已确认"
      ],
      "patterns": [
        "当前无(?:独立)?待定项",
        "当前无已确认待补充材料",
        "当前无阻塞[^。\\n]*"
      ],
      "guidance": "S6 面向业务读者，应改为待确认事项、尚未确认、暂无单独列出的待确认事项等读者语言。"
    },
    {
      "id": "internal_validation_language",
      "label": "内部验收语境",
      "severity": "error",
      "terms": [
        "可验收字段",
        "可验收的数据规则",
        "落到可验收"
      ],
      "guidance": "改成明确字段定义、明确数据定义、形成可确认的展示或计算规则。"
    },
    {
      "id": "metaphor_or_process_language",
      "label": "过程/隐喻化表达",
      "severity": "warn",
      "terms": [
        "污染"
      ],
      "guidance": "优先改为影响、混入、干扰、误导等更直接表达。"
    }
  ]
}
